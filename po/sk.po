#. * General
#. section: General
#: terminal/terminal-preferences-dialog.c:258
#: terminal/terminal-preferences-dialog.c:1158
msgid "General"
msgstr "Všeobecné"

#. section: Title
#: terminal/terminal-preferences-dialog.c:266
msgid "Title"
msgstr "Titulok"

#: terminal/terminal-preferences-dialog.c:268
msgid "_Initial title:"
msgstr "Počiatočný _titulok:"

#: terminal/terminal-preferences-dialog.c:284
msgid "Dynamically-set title:"
msgstr "Dynamicky nastavený názov:"

#: terminal/terminal-preferences-dialog.c:290
msgid "Replaces initial title"
msgstr "Nahradí počiatočný titulok"

#: terminal/terminal-preferences-dialog.c:291
msgid "Goes before initial title"
msgstr "Pred počiatočný titulok"

#: terminal/terminal-preferences-dialog.c:292
msgid "Goes after initial title"
msgstr "Za počiatočný titulok"

#: terminal/terminal-preferences-dialog.c:293
msgid "Isn't displayed"
msgstr "Nezobrazené"

#. section: Command
#: terminal/terminal-preferences-dialog.c:305
msgid "Command"
msgstr "Príkaz"

#: terminal/terminal-preferences-dialog.c:307
msgid "_Run command as login shell"
msgstr "_Spustiť príkaz v prihlasovacom shelli"

#: terminal/terminal-preferences-dialog.c:311
msgid ""
"Select this option to force Terminal to run your shell as a login shell when"
" you open new terminals. See the documentation of your shell for details "
"about differences between running it as interactive shell and running it as "
"login shell."
msgstr "Výberom tejto voľby donútite Terminál, aby zobrazoval prihlasovacie rozhranie pri otvorení nových terminálov. Pozrite dokumentáciu vášho shellu pre viac informácii o rozdiele v spustení interaktívneho shellu a spustením ako prihlasovacieho shellu."

#: terminal/terminal-preferences-dialog.c:322
msgid "_Run a custom command instead of my shell"
msgstr "_Spustiť vlastný príkaz namiesto môjho shellu"

#: terminal/terminal-preferences-dialog.c:326
msgid ""
"Select this option to force Terminal to run a custom command instead of your"
" shell when you open new terminals"
msgstr "Túto možnosť vyberte, ak chcete, aby Terminál pri otváraní nových terminálov spustil vlastný príkaz namiesto vášho shellu"

#: terminal/terminal-preferences-dialog.c:334
msgid "Custom command:"
msgstr "Vlastný príkaz:"

#: terminal/terminal-preferences-dialog.c:359
msgid "_Working directory:"
msgstr "_Pracovný adresár:"

#: terminal/terminal-preferences-dialog.c:363
msgid ""
"Select this option to make new terminals (tabs or windows) use custom "
"working directory. Otherwise, current working directory will be used."
msgstr "Túto možnosť vyberte, ak chcete, aby nové terminály (karty alebo okná) používali pracovný adresár, ktorý je tu špecifikovaný. V opačnom prípade sa použije aktuálny pracovný adresár."

#. section: Scrolling
#: terminal/terminal-preferences-dialog.c:384
msgid "Scrolling"
msgstr "Posun"

#: terminal/terminal-preferences-dialog.c:386
msgid "_Scroll on output"
msgstr "_Posúvať pri výstupe"

#: terminal/terminal-preferences-dialog.c:390
msgid ""
"This option controls whether the terminal will scroll down automatically "
"whenever new output is generated by the commands running inside the "
"terminal."
msgstr "Táto voľba určuje, či sa bude obsah terminálu automaticky posúvať pri generovaní výstupu programu bežiaceho v termináli."

#: terminal/terminal-preferences-dialog.c:396
msgid "_Scroll on keystroke"
msgstr "_Posúvať pri stlačení klávesy"

#: terminal/terminal-preferences-dialog.c:400
msgid ""
"Enables you to press any key on the keyboard to scroll down the terminal to "
"the command prompt."
msgstr "Spôsobí posunutie obsahu terminálu dole pri stlačení ľubovoľnej klávesy."

#: terminal/terminal-preferences-dialog.c:410
msgid "_Enable kinetic scrolling"
msgstr "_Povoliť kinetické posúvanie"

#: terminal/terminal-preferences-dialog.c:414
msgid ""
"This controls whether scrolling \"coasts\" to a stop when releasing a "
"touchpad or touchscreen."
msgstr "Toto ovláda posun pri uvoľnení rolovania po touchpade alebo dotykovej obrazovke."

#: terminal/terminal-preferences-dialog.c:423
msgid "Scrollbar is:"
msgstr "Posuvník je:"

#: terminal/terminal-preferences-dialog.c:429
msgid "Disabled"
msgstr "Zakázaný"

#: terminal/terminal-preferences-dialog.c:430
msgid "On the left side"
msgstr "Na ľavej strane"

#: terminal/terminal-preferences-dialog.c:431
msgid "On the right side"
msgstr "Na pravej strane"

#: terminal/terminal-preferences-dialog.c:444
msgid "Scrollback:"
msgstr "Posúvanie späť:"

#: terminal/terminal-preferences-dialog.c:460
msgid "_Unlimited Scrollback"
msgstr "_Neobmedzené posúvanie späť"

#: terminal/terminal-preferences-dialog.c:464
msgid "This controls whether the terminal will have no limits on scrollback."
msgstr "Určuje, či terminál nebude mať obmedzenia pri spätnom rolovaní."

#: terminal/terminal-preferences-dialog.c:471
msgid "_Enable overlay scrolling (Requires restart)"
msgstr "_Povoliť prekrývanie pri posúvaní (vyžaduje reštart)"

#: terminal/terminal-preferences-dialog.c:475
msgid ""
"This controls whether scrollbar is drawn as an overlay (auto-hide) or not."
msgstr "Určuje, či sa posuvník nakreslí ako prekrytie (automatické skrývanie) alebo nie."

#. section: Cursor
#: terminal/terminal-preferences-dialog.c:482
msgid "Cursor"
msgstr "Kurzor"

#: terminal/terminal-preferences-dialog.c:484
msgid "Cursor shape:"
msgstr "Tvar kurzora:"

#: terminal/terminal-preferences-dialog.c:490
msgid "Block"
msgstr "Blok"

#: terminal/terminal-preferences-dialog.c:491
msgid "I-Beam"
msgstr "Tvar I"

#: terminal/terminal-preferences-dialog.c:492
msgid "Underline"
msgstr "Podčiarkovník"

#: terminal/terminal-preferences-dialog.c:502
msgid "Cursor blinks"
msgstr "Blikanie kurzora"

#: terminal/terminal-preferences-dialog.c:506
msgid "This option controls whether the cursor will be blinking or not."
msgstr "Táto voľba ovláda, či bude kruzor blikať alebo nie."

#. section: Clipboard
#: terminal/terminal-preferences-dialog.c:513
msgid "Clipboard"
msgstr "Schránka"

#: terminal/terminal-preferences-dialog.c:515
msgid "Automatically copy selection to clipboard"
msgstr "Automaticky skopírovať výber do schránky"

#: terminal/terminal-preferences-dialog.c:522
msgid "Show unsafe paste dialog"
msgstr "Zobraziť upozornenie pri nebezpečnom vkladaní"

#: terminal/terminal-preferences-dialog.c:526
msgid ""
"Show a dialog that allows one to edit text that is considered unsafe for "
"pasting"
msgstr "Zobraziť dialóg, ktorý umožňuje úpravy textu, ktorý sa považuje za nebezpečný pre vkladanie"

#. * Drop-down
#: terminal/terminal-preferences-dialog.c:535
msgid "Drop-down"
msgstr "Rozbalenie"

#. section: Behavior
#: terminal/terminal-preferences-dialog.c:544
msgid "Behavior"
msgstr "Správanie"

#: terminal/terminal-preferences-dialog.c:546
msgid "_Keep window open when it loses focus"
msgstr "_Ponechať okno otvorené, keď stratí zameranie"

#: terminal/terminal-preferences-dialog.c:556
msgid "_Use app shortcut to focus the window"
msgstr "_Na zaostrenie okna použite skratku aplikácie"

#: terminal/terminal-preferences-dialog.c:560
msgid ""
"If enabled, the app shortcut for 'xfce4-terminal --drop-down', which "
"normally opens and closes the window, will give it focus if the option to "
"keep the window open is checked."
msgstr "Ak je toto povolené, skratka aplikácie pre 'xfce4-terminal --drop-down', ktorá normálne otvára a zatvára okno ho zaostrí, ak je povolená možnosť udržiavať otvorené okno."

#: terminal/terminal-preferences-dialog.c:571
msgid "_Always keep window above"
msgstr "_Vždy mať okno navrchu"

#: terminal/terminal-preferences-dialog.c:584
msgid "_Show status icon in notification area"
msgstr "_Zobraziť stavovú ikonu v oznamovacej oblasti"

#. section: Appearance & Animation
#: terminal/terminal-preferences-dialog.c:593
msgid "Appearance and Animation"
msgstr "Vzhľad a animácia"

#: terminal/terminal-preferences-dialog.c:595
msgid "Width:"
msgstr "Šírka:"

#: terminal/terminal-preferences-dialog.c:617
msgid "Height:"
msgstr "Výška:"

#: terminal/terminal-preferences-dialog.c:639
#: terminal/terminal-preferences-dialog.c:918
msgid "Opacity:"
msgstr "Nepriehľadnosť:"

#: terminal/terminal-preferences-dialog.c:661
msgid "Duration:"
msgstr "Trvanie:"

#. TRANSLATORS: the unit for milliseconds
#: terminal/terminal-preferences-dialog.c:676
msgid "ms"
msgstr "ms"

#: terminal/terminal-preferences-dialog.c:684
msgid "_Always show tabs"
msgstr "Vždy zobr_aziť karty"

#: terminal/terminal-preferences-dialog.c:694
msgid "_Show window borders"
msgstr "_Zobraziť okraje okien"

#. section: Position
#: terminal/terminal-preferences-dialog.c:703
msgid "Position"
msgstr "Pozícia"

#: terminal/terminal-preferences-dialog.c:705
msgid "Left"
msgstr "Vľavo"

#: terminal/terminal-preferences-dialog.c:727
msgid "Right"
msgstr "Vpravo"

#: terminal/terminal-preferences-dialog.c:735
msgid "Up"
msgstr "Nahor"

#: terminal/terminal-preferences-dialog.c:749
msgid "Down"
msgstr "Nadol"

#: terminal/terminal-preferences-dialog.c:757
msgid "_Move to monitor with pointer"
msgstr "_Presunúť na monitor s ukazovateľom"

#. * Appearance
#: terminal/terminal-preferences-dialog.c:769
msgid "Appearance"
msgstr "Vzhľad"

#. section: Font
#: terminal/terminal-preferences-dialog.c:777
msgid "Font"
msgstr "Písmo"

#: terminal/terminal-preferences-dialog.c:779
msgid "_Use system font"
msgstr "_Použiť systémové písmo"

#: terminal/terminal-preferences-dialog.c:783
msgid "Enable this to use system-wide monospace font."
msgstr "Povolením tejto voľby sa použije systémové písmo s pevnou šírkou."

#: terminal/terminal-preferences-dialog.c:803
msgid "_Allow bold text"
msgstr "_Povoliť tučný text"

#: terminal/terminal-preferences-dialog.c:807
msgid ""
"Enable this to allow applications running inside the terminal windows to use"
" bold font."
msgstr "Povolením tejto voľby sa umožní aplikáciám bežiacim v termináli používať tučné písmo."

#: terminal/terminal-preferences-dialog.c:814
msgid "Text blinks:"
msgstr "Text bliká:"

#: terminal/terminal-preferences-dialog.c:815
msgid ""
"Controls whether text in the terminal is allowed to blink when '\\e[5m' "
"escape codes are used."
