#. section: Font
#: terminal/terminal-preferences-dialog.c:777
msgid "Font"
msgstr "Tipus de lletra"

#: terminal/terminal-preferences-dialog.c:779
msgid "_Use system font"
msgstr "_Utilitza el tipus de lletra del sistema"

#: terminal/terminal-preferences-dialog.c:783
msgid "Enable this to use system-wide monospace font."
msgstr "Habiliteu-ho per a usar la lletra monoespai d'arreu del sistema."

#: terminal/terminal-preferences-dialog.c:803
msgid "_Allow bold text"
msgstr "Habilit_a el text el negreta"

#: terminal/terminal-preferences-dialog.c:807
msgid ""
"Enable this to allow applications running inside the terminal windows to use"
" bold font."
msgstr "Habiliteu-ho per a permetre que les aplicacions que s'executin a les finestres del terminal puguin usar text en negreta."

#: terminal/terminal-preferences-dialog.c:814
msgid "Text blinks:"
msgstr "El text parpelleja:"

#: terminal/terminal-preferences-dialog.c:815
msgid ""
"Controls whether text in the terminal is allowed to blink when '\\e[5m' "
"escape codes are used."
msgstr "Controla si es permet que parpellegi el text del terminal quan s'utilitzen els codis d'escapada «\\e[5m»."

