#. section: Font
#: terminal/terminal-preferences-dialog.c:777
msgid "Font"
msgstr "Fonte"

#: terminal/terminal-preferences-dialog.c:779
msgid "_Use system font"
msgstr "_Utiliser la police du système"

#: terminal/terminal-preferences-dialog.c:783
msgid "Enable this to use system-wide monospace font."
msgstr "Activer ceci pour utiliser la police à espacement fixe du système."

#: terminal/terminal-preferences-dialog.c:803
msgid "_Allow bold text"
msgstr "_Autoriser le texte en gras"

#: terminal/terminal-preferences-dialog.c:807
msgid ""
"Enable this to allow applications running inside the terminal windows to use"
" bold font."
msgstr "Activer ceci pour autoriser les applications en cours d’exécution dans le terminal à utiliser du texte en gras."

#: terminal/terminal-preferences-dialog.c:814
msgid "Text blinks:"
msgstr "Le texte clignote :"

#: terminal/terminal-preferences-dialog.c:815
msgid ""
"Controls whether text in the terminal is allowed to blink when '\\e[5m' "
"escape codes are used."
msgstr "Vérifie si du texte dans le terminal peut clignoter lorsque des codes d’échappement « \\e[5m » sont utilisés."

#: terminal/terminal-preferences-dialog.c:822
msgid "Never"
msgstr "Jamais"

#: terminal/terminal-preferences-dialog.c:823
msgid "When focused"
msgstr "Lorsqu’il a le focus"

#: terminal/terminal-preferences-dialog.c:824
msgid "When unfocused"
