#: terminal/terminal-preferences-dialog.c:779
msgid "_Use system font"
msgstr "Usar la _tipografía del sistema"

#: terminal/terminal-preferences-dialog.c:783
msgid "Enable this to use system-wide monospace font."
msgstr "Active esta opción para utilizar la tipografía monoespaciada del sistema."

#: terminal/terminal-preferences-dialog.c:803
msgid "_Allow bold text"
msgstr "Permitir te_xto en negrita"

#: terminal/terminal-preferences-dialog.c:807
msgid ""
"Enable this to allow applications running inside the terminal windows to use"
" bold font."
msgstr "Active esta opción para permitir que las aplicaciones que se ejecuten en las ventanas del terminal usen texto en negrita."

#: terminal/terminal-preferences-dialog.c:814
msgid "Text blinks:"
msgstr "Parpadeo del texto:"

#: terminal/terminal-preferences-dialog.c:815
