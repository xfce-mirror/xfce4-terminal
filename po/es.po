#: terminal/terminal-options.c:247
msgid ""
"Option \"--default-display\" requires specifying the default X display as "
"its parameter"
msgstr "La opción «--default-display» requiere que se especifique el visor X predeterminado como parámetro"

#: terminal/terminal-options.c:263
msgid ""
"Option \"--default-working-directory\" requires specifying the default "
"working directory as its parameter"
msgstr "La opción «--default-working-directory» requiere que se especifique la carpeta de trabajo predeterminada como parámetro"

#: terminal/terminal-options.c:280
msgid ""
"Option \"--execute/-x\" requires specifying the command to run on the rest "
"of the command line separated from \"--execute/-x\""
msgstr "La opción «--execute/-x» requiere que se especifique la orden que se ejecutará en el resto de la línea de órdenes separada de «--execute/-x»"

#: terminal/terminal-options.c:298
msgid ""
"Option \"--command/-e\" requires specifying the command to run as its "
"parameter"
msgstr "La opción «--command/-e» requiere que se especifique la orden para ejecutar como su parámetro"

#: terminal/terminal-options.c:314
msgid ""
"Option \"--working-directory\" requires specifying the working directory as "
"its parameter"
msgstr "La opción «--working-directory» requiere que se especifique el directorio de trabajo como parámetro"

#: terminal/terminal-options.c:329
msgid "Option \"--title/-T\" requires specifying the title as its parameter"
msgstr "La opción «--title/-T» requiere que se especifique el título como parámetro"

#: terminal/terminal-options.c:344
msgid ""
"Option \"--dynamic-title-mode\" requires specifying the dynamic title mode "
"as its parameter"
msgstr "La opción «--dynamic-title-mode» requiere que se especifique el modo del título dinámico de ventana como parámetro"

#: terminal/terminal-options.c:359
#, c-format
msgid "Invalid argument for option \"--dynamic-title-mode\": %s"
msgstr "Argumento no valido para la opción «--dynamic-title-mode»: %s"

#: terminal/terminal-options.c:369
msgid ""
"Option \"--initial-title\" requires specifying the initial title as its "
"parameter"
msgstr "La opción «--initial-title» requiere que se especifique un título inicial como parámetro"

#: terminal/terminal-options.c:393 terminal/terminal-options.c:412
#, c-format
msgid "Option \"%s\" requires specifying the color as its parameter"
msgstr "La opción «%s» requiere que se especifique el color como parámetro"

#: terminal/terminal-options.c:400 terminal/terminal-options.c:419
#, c-format
msgid "Unable to parse color: %s"
msgstr "No se puede analizar el color: %s"

#: terminal/terminal-options.c:430
msgid "Option \"--display\" requires specifying the X display as its parameter"
msgstr "La opción «--display» requiere que se especifique el visor X como parámetro"

#: terminal/terminal-options.c:445
msgid ""
"Option \"--geometry\" requires specifying the window geometry as its "
"parameter"
msgstr "La opción «--geometry» requiere que se especifique la geometría de la ventana como parámetro"

#: terminal/terminal-options.c:460
msgid "Option \"--role\" requires specifying the window role as its parameter"
msgstr "La opción «--role» requiere que se especifique el rol de la ventana como parámetro"

#: terminal/terminal-options.c:475
msgid ""
"Option \"--workspace\" requires specifying the workspace number as its "
"parameter"
msgstr "La opción «--workspace» requiere que se especifique el número del espacio de trabajo como parámetro"

#: terminal/terminal-options.c:489
msgid ""
"Option \"--sm-client-id\" requires specifying the unique session id as its "
"parameter"
msgstr "La opción «--sm-client-id» requiere que se especifique el identificador de sesión como parámetro"

#: terminal/terminal-options.c:504
msgid ""
"Option \"--startup-id\" requires specifying the startup id as its parameter"
msgstr "La opción «--startup-id» requiere que se especifique el identificador de inicio como parámetro"

#: terminal/terminal-options.c:520
msgid ""
"Option \"--icon/-I\" requires specifying an icon name or filename as its "
"parameter"
msgstr "La opción «--icon/-I» requiere que se especifique un nombre de icono o un nombre de archivo como parámetro"

#: terminal/terminal-options.c:602
msgid "Option \"--font\" requires specifying the font name as its parameter"
msgstr "La opción «--font» requiere que se especifique el nombre de la tipografía como parámetro"

#: terminal/terminal-options.c:620
#, c-format
msgid "Option \"--zoom\" requires specifying the zoom (%d .. %d) as its parameter"
msgstr "La opción «--zoom» requiere que se especifique la ampliación (%d .. %d) como parámetro"

#: terminal/terminal-options.c:636
msgid "Option \"--class\" requires specifying the class name as its parameter"
msgstr "La opción \"--class\" requiere especificar el nombre de la clase como su parámetro"

#: terminal/terminal-options.c:654
#, c-format
msgid "Unknown option \"-%c\""
msgstr "Opción desconocida «-%c»"

#: terminal/terminal-options.c:657
#, c-format
msgid "Unknown option \"%s\""
msgstr "Opción desconocida «%s»"

