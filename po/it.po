#: terminal/terminal-preferences-dialog.c:769
msgid "Appearance"
msgstr "Aspetto"

#. section: Font
#: terminal/terminal-preferences-dialog.c:777
msgid "Font"
msgstr "Carattere"

#: terminal/terminal-preferences-dialog.c:779
msgid "_Use system font"
msgstr "_Usa carattere di sistema"

#: terminal/terminal-preferences-dialog.c:783
msgid "Enable this to use system-wide monospace font."
msgstr "Abilita questa opzione per usare il carattere monospace a livello di sistema."

#: terminal/terminal-preferences-dialog.c:803
msgid "_Allow bold text"
msgstr "_Consenti testo in grassetto"

#: terminal/terminal-preferences-dialog.c:807
msgid ""
"Enable this to allow applications running inside the terminal windows to use"
" bold font."
msgstr "Abilitare questa opzione per consentire l'utilizzo del testo in grassetto alle applicazioni in esecuzione all'interno delle finestre di terminale."

#: terminal/terminal-preferences-dialog.c:814
msgid "Text blinks:"
msgstr "Testo lampeggiante:"

#: terminal/terminal-preferences-dialog.c:815
msgid ""
"Controls whether text in the terminal is allowed to blink when '\\e[5m' "
"escape codes are used."
msgstr "Controlla se al testo nel terminale è permesso di lampeggiare quando i codici di escape '\\e[5m' sono usati."

#: terminal/terminal-preferences-dialog.c:822
msgid "Never"
msgstr "Mai"

#: terminal/terminal-preferences-dialog.c:823
msgid "When focused"
msgstr "Quando in primo piano"

#: terminal/terminal-preferences-dialog.c:824
msgid "When unfocused"
msgstr "Quando non in primo piano"

#: terminal/terminal-preferences-dialog.c:825
