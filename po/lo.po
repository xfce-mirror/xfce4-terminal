#: terminal/terminal-options.c:247
msgid ""
"Option \"--default-display\" requires specifying the default X display as "
"its parameter"
msgstr "ຕົວເລືອກ \"--default-display\" ຕ້ອງການການກຳນົດຄ່າຈໍສະແດງຜົນ X ເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:263
msgid ""
"Option \"--default-working-directory\" requires specifying the default "
"working directory as its parameter"
msgstr "ຕົວເລືອກ \"--default-working-directory\" ຕ້ອງການການກຳນົດໄດເຣັກທໍຣີເຮັດວຽກເລີ່ມຕົ້ນເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:280
msgid ""
"Option \"--execute/-x\" requires specifying the command to run on the rest "
"of the command line separated from \"--execute/-x\""
msgstr "ຕົວເລືອກ \"--execute/-x\" ຕ້ອງການການກຳນົດຄຳສັ່ງທີ່ຈະໃຫ້ເຮັດວຽກ"

#: terminal/terminal-options.c:298
msgid ""
"Option \"--command/-e\" requires specifying the command to run as its "
"parameter"
msgstr "ຕົວເລືອກ \"--command/-e\" ຕ້ອງການການກຳນົດຄຳສັ່ງເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:315
msgid ""
"Option \"--working-directory\" requires specifying the working directory as "
"its parameter"
msgstr "ຕົວເລືອກ \"--working-directory\" ຕ້ອງການການກຳນົດໄດເຣັກທໍຣີເຮັດວຽກເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:330
msgid "Option \"--title/-T\" requires specifying the title as its parameter"
msgstr "ຕົວເລືອກ \"--title/-T\" ຕ້ອງການການກຳນົດຫົວຂໍ້ເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:345
msgid ""
"Option \"--dynamic-title-mode\" requires specifying the dynamic title mode "
"as its parameter"
msgstr "ຕົວເລືອກ \"--dynamic-title-mode\" ຕ້ອງການການກຳນົດໂໝດຫົວຂໍ້ໄດນາມິກເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:360
#, c-format
msgid "Invalid argument for option \"--dynamic-title-mode\": %s"
msgstr "ອາກິວເມັນບໍ່ຖືກຕ້ອງສຳລັບຕົວເລືອກ \"--dynamic-title-mode\": %s"

#: terminal/terminal-options.c:370
msgid ""
"Option \"--initial-title\" requires specifying the initial title as its "
"parameter"
msgstr "ຕົວເລືອກ \"--initial-title\" ຕ້ອງການການກຳນົດຫົວຂໍ້ເລີ່ມຕົ້ນເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:394 terminal/terminal-options.c:413
#, c-format
msgid "Option \"%s\" requires specifying the color as its parameter"
msgstr "ຕົວເລືອກ \"%s\" ຕ້ອງການການກຳນົດສີເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:401 terminal/terminal-options.c:420
#, c-format
msgid "Unable to parse color: %s"
msgstr "ບໍ່ສາມາດອ່ານຄ່າສີ: %s"

#: terminal/terminal-options.c:431
msgid "Option \"--display\" requires specifying the X display as its parameter"
msgstr "ຕົວເລືອກ \"--display\" ຕ້ອງການການກຳນົດຈໍສະແດງຜົນ X ເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:446
msgid ""
"Option \"--geometry\" requires specifying the window geometry as its "
"parameter"
msgstr "ຕົວເລືອກ \"--geometry\" ຕ້ອງການການກຳນົດຂະໜາດວິນໂດເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:461
msgid "Option \"--role\" requires specifying the window role as its parameter"
msgstr "ຕົວເລືອກ \"--role\" ຕ້ອງການການກຳນົດບົດບາດວິນໂດເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:476
msgid ""
"Option \"--workspace\" requires specifying the workspace number as its "
"parameter"
msgstr "ຕົວເລືອກ \"--workspace\" ຕ້ອງການການກຳນົດໝາຍເລກພື້ນທີ່ເຮັດວຽກເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:490
msgid ""
"Option \"--sm-client-id\" requires specifying the unique session id as its "
"parameter"
msgstr "ຕົວເລືອກ \"--sm-client-id\" ຕ້ອງການການກຳນົດໄອດີເຊດຊັນເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:505
msgid ""
"Option \"--startup-id\" requires specifying the startup id as its parameter"
msgstr "ຕົວເລືອກ \"--startup-id\" ຕ້ອງການການກຳນົດໄອດີການເລີ່ມຕົ້ນເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:521
msgid ""
"Option \"--icon/-I\" requires specifying an icon name or filename as its "
"parameter"
msgstr "ຕົວເລືອກ \"--icon/-I\" ຕ້ອງການການກຳນົດຊື່ໄອຄອນ ຫຼື ຊື່ໄຟລ໌ເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:603
msgid "Option \"--font\" requires specifying the font name as its parameter"
msgstr "ຕົວເລືອກ \"--font\" ຕ້ອງການການກຳນົດຊື່ຕົວອັກສອນເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:621
#, c-format
msgid "Option \"--zoom\" requires specifying the zoom (%d .. %d) as its parameter"
msgstr "ຕົວເລືອກ \"--zoom\" ຕ້ອງການການກຳນົດການຊູມ (%d .. %d) ເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:637
msgid "Option \"--class\" requires specifying the class name as its parameter"
msgstr "ຕົວເລືອກ \"--class\" ຕ້ອງການການກຳນົດຊື່ຄລາດສ໌ເປັນພາຣາມິເຕີ"

#: terminal/terminal-options.c:655
#, c-format
msgid "Unknown option \"-%c\""
msgstr "ບໍ່ຮູ້ຈັກຕົວເລືອກ \"-%c\""

#: terminal/terminal-options.c:658
#, c-format
msgid "Unknown option \"%s\""
msgstr "ບໍ່ຮູ້ຈັກຕົວເລືອກ \"%s\""

